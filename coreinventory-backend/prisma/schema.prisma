generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// TENANTS
// ==========================================
model Tenant {
  id          String   @id @default(uuid())
  companyName String   @map("company_name")
  slug        String   @unique
  plan        String   @default("free")
  createdAt   DateTime @default(now()) @map("created_at")

  users        User[]
  categories   Category[]
  products     Product[]
  warehouses   Warehouse[]
  locations    Location[]
  suppliers    Supplier[]
  stock        Stock[]
  receipts     Receipt[]
  deliveries   Delivery[]
  transfers    Transfer[]
  adjustments  Adjustment[]
  stockLedger  StockLedger[]

  @@map("tenants")
}

// ==========================================
// USERS
// ==========================================
model User {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  name       String
  email      String
  password   String
  role       UserRole @default(warehouse_staff)
  otpCode    String?  @map("otp_code")
  otpExpiry  DateTime? @map("otp_expiry")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  receipts   Receipt[]
  deliveries Delivery[]
  transfers  Transfer[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

enum UserRole {
  inventory_manager
  warehouse_staff
}

// ==========================================
// CATEGORIES
// ==========================================
model Category {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  name     String

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  products Product[]

  @@index([tenantId])
  @@map("categories")
}

// ==========================================
// PRODUCTS
// ==========================================
model Product {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  name         String
  sku          String
  categoryId   String?  @map("category_id")
  unit         String   @default("pcs")
  reorderLevel Int      @default(10) @map("reorder_level")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  category        Category?       @relation(fields: [categoryId], references: [id])
  stock           Stock[]
  receiptItems    ReceiptItem[]
  deliveryItems   DeliveryItem[]
  transferItems   TransferItem[]
  adjustments     Adjustment[]
  stockLedger     StockLedger[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@map("products")
}

// ==========================================
// WAREHOUSES
// ==========================================
model Warehouse {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  name     String
  address  String?

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  locations Location[]

  @@index([tenantId])
  @@map("warehouses")
}

// ==========================================
// LOCATIONS
// ==========================================
model Location {
  id          String @id @default(uuid())
  tenantId    String @map("tenant_id")
  warehouseId String @map("warehouse_id")
  name        String
  type        String @default("storage")

  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  warehouse   Warehouse  @relation(fields: [warehouseId], references: [id])
  stock       Stock[]
  receiptItems     ReceiptItem[]
  deliveryItems    DeliveryItem[]
  sourceTransfers  Transfer[]    @relation("sourceLocation")
  destTransfers    Transfer[]    @relation("destinationLocation")
  adjustments      Adjustment[]
  stockLedger      StockLedger[]

  @@index([tenantId])
  @@index([tenantId, warehouseId])
  @@map("locations")
}

// ==========================================
// SUPPLIERS
// ==========================================
model Supplier {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  name     String
  email    String?
  phone    String?

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  receipts Receipt[]

  @@index([tenantId])
  @@map("suppliers")
}

// ==========================================
// STOCK (Real-time snapshot)
// ==========================================
model Stock {
  id         String @id @default(uuid())
  tenantId   String @map("tenant_id")
  productId  String @map("product_id")
  locationId String @map("location_id")
  quantity   Int    @default(0)

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([tenantId, productId, locationId])
  @@index([tenantId])
  @@index([tenantId, productId])
  @@map("stock")
}

// ==========================================
// RECEIPTS (Incoming)
// ==========================================
model Receipt {
  id         String        @id @default(uuid())
  tenantId   String        @map("tenant_id")
  supplierId String?       @map("supplier_id")
  status     ReceiptStatus @default(draft)
  createdBy  String        @map("created_by")
  notes      String?
  createdAt  DateTime      @default(now()) @map("created_at")
  validatedAt DateTime?    @map("validated_at")

  tenant   Tenant        @relation(fields: [tenantId], references: [id])
  supplier Supplier?     @relation(fields: [supplierId], references: [id])
  creator  User          @relation(fields: [createdBy], references: [id])
  items    ReceiptItem[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("receipts")
}

enum ReceiptStatus {
  draft
  confirmed
  validated
  cancelled
}

model ReceiptItem {
  id         String  @id @default(uuid())
  receiptId  String  @map("receipt_id")
  productId  String  @map("product_id")
  locationId String  @map("location_id")
  quantity   Int

  receipt  Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@map("receipt_items")
}

// ==========================================
// DELIVERIES (Outgoing)
// ==========================================
model Delivery {
  id           String         @id @default(uuid())
  tenantId     String         @map("tenant_id")
  customerName String         @map("customer_name")
  status       DeliveryStatus @default(draft)
  createdBy    String         @map("created_by")
  notes        String?
  createdAt    DateTime       @default(now()) @map("created_at")
  validatedAt  DateTime?      @map("validated_at")

  tenant  Tenant         @relation(fields: [tenantId], references: [id])
  creator User           @relation(fields: [createdBy], references: [id])
  items   DeliveryItem[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("deliveries")
}

enum DeliveryStatus {
  draft
  picked
  packed
  validated
  cancelled
}

model DeliveryItem {
  id         String  @id @default(uuid())
  deliveryId String  @map("delivery_id")
  productId  String  @map("product_id")
  locationId String  @map("location_id")
  quantity   Int

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@map("delivery_items")
}

// ==========================================
// TRANSFERS (Internal)
// ==========================================
model Transfer {
  id                  String         @id @default(uuid())
  tenantId            String         @map("tenant_id")
  sourceLocationId    String         @map("source_location")
  destinationLocationId String        @map("destination_location")
  status              TransferStatus @default(draft)
  createdBy           String         @map("created_by")
  notes               String?
  createdAt           DateTime       @default(now()) @map("created_at")
  validatedAt         DateTime?      @map("validated_at")

  tenant              Tenant         @relation(fields: [tenantId], references: [id])
  sourceLocation      Location       @relation("sourceLocation", fields: [sourceLocationId], references: [id])
  destinationLocation Location       @relation("destinationLocation", fields: [destinationLocationId], references: [id])
  creator             User           @relation(fields: [createdBy], references: [id])
  items               TransferItem[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("transfers")
}

enum TransferStatus {
  draft
  in_transit
  validated
  cancelled
}

model TransferItem {
  id         String @id @default(uuid())
  transferId String @map("transfer_id")
  productId  String @map("product_id")
  quantity   Int

  transfer Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@map("transfer_items")
}

// ==========================================
// ADJUSTMENTS
// ==========================================
model Adjustment {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  productId   String   @map("product_id")
  locationId  String   @map("location_id")
  previousQty Int      @map("previous_qty")
  newQty      Int      @map("new_qty")
  reason      String
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@index([tenantId])
  @@map("adjustments")
}

// ==========================================
// STOCK LEDGER (Audit Trail - Immutable)
// ==========================================
model StockLedger {
  id             String       @id @default(uuid())
  tenantId       String       @map("tenant_id")
  productId      String       @map("product_id")
  locationId     String       @map("location_id")
  movementType   MovementType @map("movement_type")
  referenceId    String?      @map("reference_id")
  quantityChange Int          @map("quantity_change")
  createdAt      DateTime     @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@index([tenantId])
  @@index([tenantId, productId])
  @@index([tenantId, movementType])
  @@index([tenantId, createdAt])
  @@map("stock_ledger")
}

enum MovementType {
  receipt
  delivery
  transfer_out
  transfer_in
  adjustment
}
