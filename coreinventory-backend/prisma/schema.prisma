generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id          String        @id @default(uuid())
  companyName String        @map("company_name")
  slug        String        @unique
  plan        String        @default("free")
  createdAt   DateTime      @default(now()) @map("created_at")
  adjustments Adjustment[]
  categories  Category[]
  deliveries  Delivery[]
  locations   Location[]
  products    Product[]
  receipts    Receipt[]
  stock       Stock[]
  stockLedger StockLedger[]
  suppliers   Supplier[]
  transfers   Transfer[]
  users       User[]
  warehouses  Warehouse[]

  @@map("tenants")
}

model User {
  id         String     @id @default(uuid())
  tenantId   String     @map("tenant_id")
  name       String
  email      String
  password   String
  role       UserRole   @default(warehouse_staff)
  otpCode    String?    @map("otp_code")
  otpExpiry  DateTime?  @map("otp_expiry")
  createdAt  DateTime   @default(now()) @map("created_at")
  deliveries Delivery[]
  receipts   Receipt[]
  transfers  Transfer[]
  tenant     Tenant     @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model Category {
  id       String    @id @default(uuid())
  tenantId String    @map("tenant_id")
  name     String
  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  products Product[]

  @@index([tenantId])
  @@map("categories")
}

model Product {
  id            String         @id @default(uuid())
  tenantId      String         @map("tenant_id")
  name          String
  sku           String
  categoryId    String?        @map("category_id")
  unit          String         @default("pcs")
  reorderLevel  Int            @default(10) @map("reorder_level")
  createdAt     DateTime       @default(now()) @map("created_at")
  adjustments   Adjustment[]
  deliveryItems DeliveryItem[]
  category      Category?      @relation(fields: [categoryId], references: [id])
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  receiptItems  ReceiptItem[]
  stock         Stock[]
  stockLedger   StockLedger[]
  transferItems TransferItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@map("products")
}

model Warehouse {
  id        String     @id @default(uuid())
  tenantId  String     @map("tenant_id")
  name      String
  address   String?
  locations Location[]
  tenant    Tenant     @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("warehouses")
}

model Location {
  id              String         @id @default(uuid())
  tenantId        String         @map("tenant_id")
  warehouseId     String         @map("warehouse_id")
  name            String
  type            String         @default("storage")
  adjustments     Adjustment[]
  deliveryItems   DeliveryItem[]
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  warehouse       Warehouse      @relation(fields: [warehouseId], references: [id])
  receiptItems    ReceiptItem[]
  stock           Stock[]
  stockLedger     StockLedger[]
  destTransfers   Transfer[]     @relation("destinationLocation")
  sourceTransfers Transfer[]     @relation("sourceLocation")

  @@index([tenantId])
  @@index([tenantId, warehouseId])
  @@map("locations")
}

model Supplier {
  id       String    @id @default(uuid())
  tenantId String    @map("tenant_id")
  name     String
  email    String?
  phone    String?
  receipts Receipt[]
  tenant   Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("suppliers")
}

model Stock {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  productId        String   @map("product_id")
  locationId       String   @map("location_id")
  quantity         Int      @default(0)
  reservedQuantity Int      @default(0) @map("reserved_quantity")
  location         Location @relation(fields: [locationId], references: [id])
  product          Product  @relation(fields: [productId], references: [id])
  tenant           Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, productId, locationId])
  @@index([tenantId])
  @@index([tenantId, productId])
  @@map("stock")
}

model Receipt {
  id          String        @id @default(uuid())
  tenantId    String        @map("tenant_id")
  supplierId  String?       @map("supplier_id")
  status      ReceiptStatus @default(draft)
  createdBy   String        @map("created_by")
  notes       String?
  createdAt   DateTime      @default(now()) @map("created_at")
  validatedAt DateTime?     @map("validated_at")
  items       ReceiptItem[]
  creator     User          @relation(fields: [createdBy], references: [id])
  supplier    Supplier?     @relation(fields: [supplierId], references: [id])
  tenant      Tenant        @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("receipts")
}

model ReceiptItem {
  id         String   @id @default(uuid())
  receiptId  String   @map("receipt_id")
  productId  String   @map("product_id")
  locationId String   @map("location_id")
  quantity   Int
  location   Location @relation(fields: [locationId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])
  receipt    Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@map("receipt_items")
}

model Delivery {
  id           String         @id @default(uuid())
  tenantId     String         @map("tenant_id")
  customerName String         @map("customer_name")
  status       DeliveryStatus @default(draft)
  createdBy    String         @map("created_by")
  notes        String?
  createdAt    DateTime       @default(now()) @map("created_at")
  validatedAt  DateTime?      @map("validated_at")
  creator      User           @relation(fields: [createdBy], references: [id])
  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  items        DeliveryItem[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("deliveries")
}

model DeliveryItem {
  id         String   @id @default(uuid())
  deliveryId String   @map("delivery_id")
  productId  String   @map("product_id")
  locationId String   @map("location_id")
  quantity   Int
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])

  @@map("delivery_items")
}

model Transfer {
  id                    String         @id @default(uuid())
  tenantId              String         @map("tenant_id")
  sourceLocationId      String         @map("source_location")
  destinationLocationId String         @map("destination_location")
  status                TransferStatus @default(draft)
  createdBy             String         @map("created_by")
  notes                 String?
  createdAt             DateTime       @default(now()) @map("created_at")
  validatedAt           DateTime?      @map("validated_at")
  items                 TransferItem[]
  creator               User           @relation(fields: [createdBy], references: [id])
  destinationLocation   Location       @relation("destinationLocation", fields: [destinationLocationId], references: [id])
  sourceLocation        Location       @relation("sourceLocation", fields: [sourceLocationId], references: [id])
  tenant                Tenant         @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("transfers")
}

model TransferItem {
  id         String   @id @default(uuid())
  transferId String   @map("transfer_id")
  productId  String   @map("product_id")
  quantity   Int
  product    Product  @relation(fields: [productId], references: [id])
  transfer   Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@map("transfer_items")
}

model Adjustment {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  productId   String   @map("product_id")
  locationId  String   @map("location_id")
  previousQty Int      @map("previous_qty")
  newQty      Int      @map("new_qty")
  reason      String
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  location    Location @relation(fields: [locationId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("adjustments")
}

model StockLedger {
  id             String       @id @default(uuid())
  tenantId       String       @map("tenant_id")
  productId      String       @map("product_id")
  locationId     String       @map("location_id")
  movementType   MovementType @map("movement_type")
  referenceId    String?      @map("reference_id")
  quantityChange Int          @map("quantity_change")
  createdAt      DateTime     @default(now()) @map("created_at")
  location       Location     @relation(fields: [locationId], references: [id])
  product        Product      @relation(fields: [productId], references: [id])
  tenant         Tenant       @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, productId])
  @@index([tenantId, movementType])
  @@index([tenantId, createdAt])
  @@map("stock_ledger")
}

enum UserRole {
  inventory_manager
  warehouse_staff
}

enum ReceiptStatus {
  draft
  confirmed
  validated
  cancelled
}

enum DeliveryStatus {
  draft
  picked
  packed
  validated
  cancelled
}

enum TransferStatus {
  draft
  in_transit
  validated
  cancelled
}

enum MovementType {
  receipt
  delivery
  transfer_out
  transfer_in
  adjustment
}
